# TalentForge deployment environment.
# Copy into Railway, Vercel, or local shell configuration. Do not commit real secrets.

# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/talentforge?ssl=require
LANGGRAPH_CHECKPOINT_DATABASE_URL=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_STATEMENT_TIMEOUT_MS=30000
SQLALCHEMY_ECHO=false

# FastAPI / frontend
TALENTFORGE_PRODUCTION_FRONTEND_ORIGIN=https://talentforge.vercel.app
TALENTFORGE_INIT_DB_ON_STARTUP=false
TALENTFORGE_CREATE_TABLES_ON_STARTUP=false
TALENTFORGE_CREATE_READONLY_ROLE_ON_STARTUP=false

# Auth
JWT_SECRET_KEY=replace-with-at-least-32-bytes-of-random-secret
JWT_ISSUER=talentforge-api
JWT_AUDIENCE=talentforge-api
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Telemetry ingestion
TALENTFORGE_WEBHOOK_SECRET=replace-with-strong-shared-webhook-secret

# OpenAI / LangGraph
OPENAI_API_KEY=sk-replace-me
TALENTFORGE_ROUTING_MODEL=gpt-5.6-luna
TALENTFORGE_FRONTIER_MODEL=gpt-5.6-terra
LANGGRAPH_TOOL_TIMEOUT_SECONDS=20
LANGGRAPH_CACHE_SIMILARITY_THRESHOLD=0.88
LANGGRAPH_CUSTOMER_COOLDOWN_HOURS=24

# Read-only Postgres MCP
POSTGRES_MCP_TRANSPORT=http
POSTGRES_MCP_URL=https://postgres-mcp.example.com/mcp
POSTGRES_MCP_AUTH_TOKEN=replace-with-mcp-token
POSTGRES_MCP_ALLOWED_TOOLS=get_customer_profile,get_interaction_history,get_customer_health_signals
POSTGRES_MCP_CONNECT_TIMEOUT_SECONDS=10
POSTGRES_MCP_READ_TIMEOUT_SECONDS=30
POSTGRES_MCP_MAX_RETRIES=2

# Email delivery
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=TalentForge <success@talentforge.example>
